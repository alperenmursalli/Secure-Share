# Copy to .env on the server and fill in real values (never commit .env)
DB_USER=secshare
DB_PASSWORD=change-me-strong-password
# Generate with: openssl rand -base64 32
JWT_SECRET=change-me-base64-secret

# Optional: bootstrap an admin account on first startup (leave blank to skip).
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-strong-admin-password
